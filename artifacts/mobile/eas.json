{
  "cli": {
    "version": ">= 7.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "production": {
      "node": "20",
      "android": {
        "buildType": "apk",
        "prebuildCommand": "npm install --legacy-peer-deps && npx expo prebuild --no-install --platform android"
      },
      "env": {
        "NPM_CONFIG_NODE_LINKER": "hoisted"
      }
    }
  },
  "submit": {
    "production": {}
  }
}