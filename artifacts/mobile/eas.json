{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "production": {
      "android": {
        "buildType": "apk",
        "prebuildCommand": "npm install --legacy-peer-deps && expo prebuild --no-install --platform android"
      },
      "env": {
        "NPM_CONFIG_NODE_LINKER": "hoisted"
      }
    }
  },
  "submit": {
    "production": {}
  }
}